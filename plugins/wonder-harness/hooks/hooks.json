{
  "description": "wonder-harness pipeline enforcement hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/init-requests.js", "timeout": 5 }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforce-init.js",   "timeout": 10 },
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforce-stage.js",  "timeout": 10 }
        ]
      }
    ]
  }
}
